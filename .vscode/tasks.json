{
  "version": "2.0.0",
  "command": "mvn",
  "tasks": [
    {
      "label": "compile",
      "type": "shell",
      "command": "mvn",
      "args": [
        "compile",
        "compile -f pom.xml"
      ],
      "problemMatcher": {
        "owner": "java",
        "fileLocation": [
          "absolute"
        ],
        "pattern": {
          "regexp": "^\\[(WARNING|ERROR)\\] (.+):\\[(\\d+),(\\d+)\\] (.+)$",
          "file": 2,
          "line": 3,
          "column": 4,
          "severity": 1,
          "message": 5
        }
      },
      "group": {
        "_id": "build",
        "isDefault": false
      }
    },
    {
      "label": "install",
      "type": "shell",
      "command": "mvn",
      "args": [
        "install",
        "install -f pom.xml"
      ],
      "problemMatcher": {
        "owner": "java",
        "fileLocation": [
          "absolute"
        ],
        "pattern": {
          "regexp": "^\\[(WARNING|ERROR)\\] (.+):\\[(\\d+),(\\d+)\\] (.+)$",
          "file": 2,
          "line": 3,
          "column": 4,
          "severity": 1,
          "message": 5
        }
      },
      "group": {
        "_id": "test",
        "isDefault": false
      }
    }
  ]
}